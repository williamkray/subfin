{
  "name": "subfin",
  "version": "0.1.0",
  "description": "OpenSubsonic-to-Jellyfin compatibility layer — Subsonic clients for your Jellyfin music library",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp src/store/schema.sql dist/store/",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "db:init": "node -e \"import('./dist/store/index.js').then(m => m.initDb())\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@jellyfin/sdk": "^0.13.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.0.0",
    "express": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "tar": "7.5.10"
  }
}
